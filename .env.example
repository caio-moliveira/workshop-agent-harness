# Agente Analítico de Vendas — variáveis de ambiente. Copie para .env (NÃO versionado): cp .env.example .env

# ---- Postgres ----
POSTGRES_DB=workshop
POSTGRES_USER=workshop
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5432

# ---- nginx (reverse proxy: única porta exposta ao host) ----
NGINX_PORT=8080
# App em:  http://localhost:8080/health  ·  POST http://localhost:8080/chat

# ---- Conexão admin (RW) usada por host tools: Alembic, seed ----
# Aponta pro Postgres exposto em localhost. No container, o compose injeta host=postgres.
DATABASE_URL=postgresql+asyncpg://workshop:troque-esta-senha@localhost:5432/workshop

# ---- Papel somente-leitura do agente (run_sql) — criado nas migrations (#2) ----
AGENTE_RO_PASSWORD=troque-esta-senha-ro

# ---- Qdrant (vetorial: 3 coleções camada_semantica/diagnostico/prescricao) ----
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# ---- MinIO (object store: corpus bruto). Defaults locais; troque em produção. ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=corpus

# ---- Embeddings (OpenAI) — usados na ingestão (seed/ingest.py) ----
OPENAI_API_KEY=sk-troque-esta-chave        # obrigatório para a ingestão
EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072
