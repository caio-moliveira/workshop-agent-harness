# Bússola — variáveis de ambiente (esqueleto andante, issue #1).
# Copie para .env (NÃO versionado) e troque os segredos:  cp .env.example .env

# ---- Postgres (sobe vazio nesta fatia) ----
POSTGRES_DB=bussola
POSTGRES_USER=bussola
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5432

# ---- nginx (reverse proxy: única porta exposta ao host) ----
NGINX_PORT=8080
# App acessível em:  http://localhost:8080/health   ·   POST http://localhost:8080/chat

# DATABASE_URL do api é montada pelo docker-compose a partir das variáveis acima.
# Para rodar o backend localmente (fora do compose):
#   DATABASE_URL=postgresql+asyncpg://bussola:troque-esta-senha@localhost:5432/bussola
